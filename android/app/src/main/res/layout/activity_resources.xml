<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/background_dark">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Support &amp; Guidelines"
        android:textColor="@color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Browse helpful articles, design requirements, and customer support channels."
        android:textColor="@color/text_secondary_dark"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <HorizontalScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:scrollbars="none"
        android:layout_marginBottom="12dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/btnResAll"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="All Articles"
                android:layout_marginEnd="8dp"
                android:textColor="@color/black"
                android:backgroundTint="@color/cyan_400" />

            <Button
                android:id="@+id/btnResFaq"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="FAQs"
                android:layout_marginEnd="8dp"
                android:textColor="@color/white"
                android:backgroundTint="@color/surface_variant_dark" />

            <Button
                android:id="@+id/btnResGuides"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Print Guidelines"
                android:layout_marginEnd="8dp"
                android:textColor="@color/white"
                android:backgroundTint="@color/surface_variant_dark" />

            <Button
                android:id="@+id/btnResSupport"
                style="?android:attr/buttonStyleSmall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support Info"
                android:textColor="@color/white"
                android:backgroundTint="@color/surface_variant_dark" />

        </LinearLayout>
    </HorizontalScrollView>

    <TextView
        android:id="@+id/tvEmptyResources"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:layout_marginTop="32dp"
        android:text="No articles found."
        android:textColor="@color/text_secondary_dark"
        android:textSize="16sp"
        android:visibility="gone" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvResources"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</LinearLayout>
