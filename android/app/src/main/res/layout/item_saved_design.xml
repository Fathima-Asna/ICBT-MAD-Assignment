<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:layout_marginVertical="8dp"
    android:padding="16dp"
    android:background="@color/surface_dark"
    android:elevation="2dp">

    <TextView
        android:id="@+id/tvDesignName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="18sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvCustomText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary_dark"
        android:textSize="14sp"
        android:layout_marginTop="4dp" />

    <TextView
        android:id="@+id/tvDesignUrl"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textColor="@color/cyan_200"
        android:textSize="12sp"
        android:layout_marginTop="4dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginTop="12dp"
        android:gravity="end">

        <Button
            android:id="@+id/btnDeleteDesign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Delete"
            android:textColor="@color/white"
            android:backgroundTint="@color/error"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/btnUseDesign"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Use Design"
            android:textColor="@color/black"
            android:backgroundTint="@color/cyan_400" />

    </LinearLayout>

</LinearLayout>
