<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.printxpress.android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:name=".PrintXpressApp"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.PrintXpress"
        android:networkSecurityConfig="@xml/network_security_config"
        android:usesCleartextTraffic="false">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity android:name=".ui.auth.LoginActivity" />
        <activity android:name=".ui.auth.RegisterActivity" />
        <activity android:name=".ui.auth.ForgotPasswordActivity" />
        <activity android:name=".ui.product.ProductListActivity" />
        <activity android:name=".ui.product.ProductDetailActivity" />
        <activity android:name=".ui.order.OrderSummaryActivity" />
        <activity android:name=".ui.order.OrderHistoryActivity" />

        <activity android:name=".ui.profile.ProfileActivity" />
        <activity android:name=".ui.design.SavedDesignsActivity" />
        <activity android:name=".ui.gallery.SampleGalleryActivity" />
        <activity android:name=".ui.resources.ResourcesActivity" />
        <activity android:name=".ui.notification.NotificationsActivity" />
        <activity android:name=".ui.admin.AdminDashboardActivity" />
        <activity android:name=".ui.admin.AdminOrdersActivity" />
        <activity android:name=".ui.admin.AdminProductsActivity" />
        <activity android:name=".ui.admin.AdminSamplesActivity" />
        <activity android:name=".ui.admin.AdminPromotionsActivity" />
        <activity android:name=".ui.admin.AdminFAQsActivity" />

    </application>

</manifest>
