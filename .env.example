# PrintXpress Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit the .env file to version control.

# Supabase project URL (Settings -> API in Supabase Dashboard)
SUPABASE_URL=https://your-project-id.supabase.co/

# Supabase anon/public key (Settings -> API in Supabase Dashboard)
SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth 2.0 Web Client ID (Google Cloud Console -> Credentials)
# Also add this as an authorized client in Supabase Auth -> Providers -> Google
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id.apps.googleusercontent.com

# Release keystore signing credentials
RELEASE_STORE_FILE=printxpress-release.keystore
RELEASE_STORE_PASSWORD=your-keystore-password
RELEASE_KEY_ALIAS=your-key-alias
RELEASE_KEY_PASSWORD=your-key-password
