# PrintXpress Environment Configuration
#
# These are the live values already baked into the app (android/app/src/main/java/
# com/printxpress/android/data/remote/SupabaseClient.java and android/app/src/main/
# res/values/strings.xml) - anyone who builds this project or installs a release APK
# built from it gets a fully working app with zero setup. This file is documentation
# only; the app does not read it at build or run time.
#
# The Supabase anon key and Google OAuth Web Client ID are meant to be public/client-side
# values (that's how Supabase and Google Sign-In are designed to work) - safe to commit.

# Supabase project URL (Settings -> API in Supabase Dashboard)
SUPABASE_URL=https://rydpgctypusymxsuouqs.supabase.co/

# Supabase anon/public key (Settings -> API in Supabase Dashboard)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InJ5ZHBnY3R5cHVzeW14c3VvdXFzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODQyNzIwNDgsImV4cCI6MjA5OTg0ODA0OH0.j5gJEIGJmNJx9xRAeiYu6pzykKmzFHLvUWSnmbQRjU8

# Google OAuth 2.0 Web Client ID (Google Cloud Console -> Credentials)
# Also added as an authorized client in Supabase Auth -> Providers -> Google
GOOGLE_WEB_CLIENT_ID=552691536919-h68dqca9vb0mc8k9i0cq2qgi00fh9bkn.apps.googleusercontent.com

# Release keystore signing credentials - these ARE secret and are NEVER committed.
# Real values live only in the local, gitignored android/app/release-keystore.properties
# file on the machine that builds signed release APKs.
RELEASE_STORE_FILE=printxpress-release.keystore
RELEASE_STORE_PASSWORD=your-keystore-password
RELEASE_KEY_ALIAS=your-key-alias
RELEASE_KEY_PASSWORD=your-key-password
